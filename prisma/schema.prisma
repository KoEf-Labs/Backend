generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum DomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

model User {
  id              String              @id @default(uuid())
  email           String              @unique
  passwordHash    String
  name            String
  phone           String?
  avatar          String?
  role            Role                @default(USER)
  emailVerified   Boolean             @default(false)
  // Social login IDs. Populated when the user links a provider (either at
  // signup via OAuth, or later from settings). An email/password user with
  // the same email will be automatically linked on OAuth sign-in so we
  // don't create orphan accounts.
  googleId        String?             @unique
  appleId         String?             @unique
  suspended       Boolean             @default(false)
  suspendedAt     DateTime?
  suspendReason   String?
  lastActivityAt  DateTime?
  mustChangePwd   Boolean             @default(false)
  // Profile completion (post email-verify, pre dashboard).
  // identityVerified is decided by IdentityVerificationService. Today it's a
  // stub that always returns true; when we wire up real MERNIS/passport it
  // will gate access via profileCompleted (no profile → no dashboard).
  profileCompleted   Boolean         @default(false)
  identityVerified   Boolean         @default(false)
  accountType        AccountType?
  dateOfBirth        DateTime?
  country            String?          // ISO 3166-1 alpha-2 (TR, US, DE…)
  nationalId         String?          // TR citizens only (11 digits)
  passportNo         String?          // foreign citizens
  companyName        String?
  companyTaxId       String?          // TR: 10 digits
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  projects        Project[]
  refreshTokens   RefreshToken[]
  verifyTokens    VerificationToken[]

  @@index([suspended])
  @@index([createdAt])
  @@index([profileCompleted])
}

enum AccountType {
  INDIVIDUAL
  CORPORATE
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model VerificationToken {
  id        String                @id @default(uuid())
  tokenHash String                @unique
  type      VerificationTokenType
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime              @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([familyId])
}

model Project {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme            String
  draftContent               Json
  publishedContent           Json?
  status                     ProjectStatus              @default(DRAFT)
  subdomain                  String?                    @unique
  customDomain               String?                    @unique
  rejectReason               String?
  domainVerificationStatus   DomainVerificationStatus?
  domainVerifiedAt           DateTime?
  deletedAt                  DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  siteViews                  SiteView[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([status])
  @@index([createdAt])
}

/// Audit trail for admin actions. Written by Backend internal endpoints
/// AND by AdminBackend via POST /api/internal/audit-log. Read by AdminBackend
/// for the history page.
model AuditLog {
  id         String   @id @default(uuid())
  adminId    String // opaque — AdminBackend AdminUser.id
  adminEmail String // denormalized for display so AdminBackend doesn't have to join
  action     String // approve | reject | suspend | unsuspend | delete | unpublish | ...
  targetType String // project | user | admin
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([action])
}

/// Daily traffic counter per project. Populated by a background cron that
/// consumes Redis counters written by /api/site/live and preview endpoints.
model SiteView {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date       DateTime // truncated to midnight UTC
  count      Int      @default(0)
  uniqueIps  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([projectId, date])
  @@index([date])
}

/// Generic settings store. Keyed by name, JSON value. Used for rate limits,
/// feature flags, anything that needs to be editable from the admin panel
/// without a deploy. Maintenance mode lives in Redis separately so the
/// middleware can read it without hitting the DB.
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/// Subdomain blacklist. A match causes /api/domain/check and project update
/// to reject the subdomain with a "blocked" error.
model DomainBlacklist {
  id        String   @id @default(uuid())
  pattern   String   @unique // exact lowercase subdomain OR regex prefixed with "re:"
  reason    String?
  addedBy   String // admin email for attribution
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Enables/disables a theme from the admin panel. Missing row = enabled.
/// Disabled themes are hidden from /api/site/themes and rejected at
/// project create/update.
model ThemeConfig {
  name      String   @id // matches themes/{name} directory
  enabled   Boolean  @default(true)
  disabledBy String?
  disabledReason String?
  updatedAt DateTime @updatedAt
}
