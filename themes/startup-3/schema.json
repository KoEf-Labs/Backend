{
  "sections": {
    "type": "sectionToggles",
    "label": "Enable / Disable Sections",
    "fields": {
      "hero": { "type": "toggle", "label": "Hero Section", "default": true },
      "about": { "type": "toggle", "label": "About Section", "default": true },
      "services": { "type": "toggle", "label": "Products Section", "default": true },
      "references": { "type": "toggle", "label": "Clients Section", "default": false },
      "careers": { "type": "toggle", "label": "Careers Section", "default": false },
      "contact": { "type": "toggle", "label": "Contact Section", "default": true }
    }
  },
  "navbar": {
    "type": "group",
    "label": "Navigation",
    "fields": {
      "logo": { "type": "text", "label": "Logo Text" },
      "links": { "type": "array", "label": "Nav Links", "schema": { "label": { "type": "text", "label": "Text" }, "href": { "type": "text", "label": "Target" } } }
    }
  },
  "hero": {
    "type": "group",
    "label": "Hero Section",
    "fields": {
      "badge": { "type": "text", "label": "Badge Text", "placeholder": "Now in Beta" },
      "title": { "type": "text", "label": "Headline" },
      "titleHighlight": { "type": "text", "label": "Highlighted Words (gradient text)" },
      "subtitle": { "type": "textarea", "label": "Subtitle" },
      "buttonText": { "type": "text", "label": "Primary Button" },
      "buttonLink": { "type": "text", "label": "Primary Button Link" },
      "secondaryButtonText": { "type": "text", "label": "Secondary Button" },
      "secondaryButtonLink": { "type": "text", "label": "Secondary Button Link" },
      "stats": { "type": "array", "label": "Stats Bar", "maxItems": 4, "schema": { "value": { "type": "text", "label": "Value" }, "label": { "type": "text", "label": "Label" } } }
    }
  },
  "about": {
    "type": "group",
    "label": "About Section",
    "fields": {
      "tagline": { "type": "text", "label": "Tagline" },
      "title": { "type": "text", "label": "Title" },
      "description": { "type": "textarea", "label": "Description" },
      "imageUrl": { "type": "image", "label": "Image" },
      "metrics": { "type": "array", "label": "Key Metrics", "maxItems": 4, "schema": { "value": { "type": "text", "label": "Value" }, "label": { "type": "text", "label": "Label" } } }
    }
  },
  "services": {
    "type": "group",
    "label": "Products / Services",
    "fields": {
      "tagline": { "type": "text", "label": "Tagline" },
      "title": { "type": "text", "label": "Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "items": { "type": "array", "label": "Products", "maxItems": 8, "schema": {
        "title": { "type": "text", "label": "Title" },
        "description": { "type": "textarea", "label": "Description" },
        "icon": { "type": "select", "label": "Icon", "options": ["brain", "zap", "database", "monitor", "shield", "code", "cloud", "rocket"] },
        "color": { "type": "select", "label": "Accent Color", "options": ["cyan", "violet", "blue", "emerald", "amber", "rose", "fuchsia", "indigo"] }
      }}
    }
  },
  "references": {
    "type": "group",
    "label": "Clients / References",
    "fields": {
      "tagline": { "type": "text", "label": "Tagline" },
      "title": { "type": "text", "label": "Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "clients": { "type": "array", "label": "Client Logos", "maxItems": 10, "schema": { "name": { "type": "text", "label": "Name" }, "logo": { "type": "image", "label": "Logo" } } },
      "testimonials": { "type": "array", "label": "Testimonials", "maxItems": 4, "schema": { "quote": { "type": "textarea", "label": "Quote" }, "author": { "type": "text", "label": "Author" }, "role": { "type": "text", "label": "Role" }, "avatar": { "type": "image", "label": "Avatar" } } }
    }
  },
  "careers": {
    "type": "group",
    "label": "Careers",
    "fields": {
      "tagline": { "type": "text", "label": "Tagline" },
      "title": { "type": "text", "label": "Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "perks": { "type": "array", "label": "Perks", "maxItems": 8, "schema": { "value": { "type": "text", "label": "Perk" } } },
      "positions": { "type": "array", "label": "Positions", "maxItems": 10, "schema": {
        "title": { "type": "text", "label": "Title" },
        "type": { "type": "select", "label": "Type", "options": ["Full-time", "Part-time", "Contract", "Internship"] },
        "location": { "type": "text", "label": "Location" },
        "salary": { "type": "text", "label": "Salary" },
        "description": { "type": "textarea", "label": "Description" },
        "tags": { "type": "array", "label": "Tech Tags", "maxItems": 5, "schema": { "value": { "type": "text", "label": "Tag" } } }
      }},
      "formTitle": { "type": "text", "label": "Form Title" },
      "formSubtitle": { "type": "text", "label": "Form Subtitle" }
    }
  },
  "contact": {
    "type": "group",
    "label": "Contact",
    "fields": {
      "tagline": { "type": "text", "label": "Tagline" },
      "title": { "type": "text", "label": "Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "phone": { "type": "text", "label": "Phone" },
      "email": { "type": "text", "label": "Email" },
      "address": { "type": "textarea", "label": "Address" },
      "mapEmbedUrl": { "type": "text", "label": "Google Maps Embed URL" }
    }
  },
  "footer": {
    "type": "group",
    "label": "Footer",
    "fields": {
      "description": { "type": "text", "label": "Description" },
      "copyright": { "type": "text", "label": "Copyright" },
      "socialLinks": { "type": "array", "label": "Social Links", "maxItems": 6, "schema": { "platform": { "type": "select", "label": "Platform", "options": ["twitter", "github", "linkedin", "youtube", "instagram", "facebook"] }, "url": { "type": "text", "label": "URL" } } },
      "links": { "type": "array", "label": "Legal Links", "maxItems": 6, "schema": { "label": { "type": "text", "label": "Text" }, "url": { "type": "text", "label": "URL" } } }
    }
  }
}
