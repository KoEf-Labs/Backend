{
  "sections": {
    "type": "sectionToggles",
    "label": "Enable / Disable Sections",
    "fields": {
      "hero": { "type": "toggle", "label": "Hero Section", "default": true },
      "about": { "type": "toggle", "label": "About Section", "default": true },
      "services": { "type": "toggle", "label": "Services Section", "default": true },
      "references": { "type": "toggle", "label": "References Section", "default": false },
      "careers": { "type": "toggle", "label": "Careers Section", "default": false },
      "contact": { "type": "toggle", "label": "Contact Section", "default": true }
    }
  },
  "navbar": {
    "type": "group",
    "label": "Navigation Bar",
    "fields": {
      "logo": { "type": "text", "label": "Logo Text", "placeholder": "Your Brand" },
      "links": {
        "type": "array",
        "label": "Nav Links",
        "schema": {
          "label": { "type": "text", "label": "Link Text" },
          "href": { "type": "text", "label": "Link Target" }
        }
      }
    }
  },
  "hero": {
    "type": "group",
    "label": "Hero Section",
    "fields": {
      "title": { "type": "text", "label": "Headline", "placeholder": "Your main headline" },
      "subtitle": { "type": "textarea", "label": "Subtitle", "placeholder": "A short description" },
      "buttonText": { "type": "text", "label": "Button Text", "placeholder": "Get Started" },
      "buttonLink": { "type": "text", "label": "Button Link", "placeholder": "#contact" },
      "imageUrl": { "type": "image", "label": "Hero Image" }
    }
  },
  "about": {
    "type": "group",
    "label": "About Section",
    "fields": {
      "title": { "type": "text", "label": "Section Title", "placeholder": "About Us" },
      "description": { "type": "textarea", "label": "Description", "placeholder": "Tell visitors about your business..." },
      "imageUrl": { "type": "image", "label": "About Image" },
      "stats": {
        "type": "array",
        "label": "Statistics",
        "maxItems": 4,
        "schema": {
          "value": { "type": "text", "label": "Value", "placeholder": "50+" },
          "label": { "type": "text", "label": "Label", "placeholder": "Projects" }
        }
      }
    }
  },
  "services": {
    "type": "group",
    "label": "Services Section",
    "fields": {
      "title": { "type": "text", "label": "Section Title", "placeholder": "Our Services" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "items": {
        "type": "array",
        "label": "Services",
        "maxItems": 6,
        "schema": {
          "title": { "type": "text", "label": "Service Title" },
          "description": { "type": "textarea", "label": "Service Description" },
          "icon": { "type": "select", "label": "Icon", "options": ["palette", "search", "cart", "cloud", "mobile", "chart", "code", "shield"] }
        }
      }
    }
  },
  "references": {
    "type": "group",
    "label": "References / Clients",
    "fields": {
      "title": { "type": "text", "label": "Section Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "clients": {
        "type": "array",
        "label": "Client Logos",
        "maxItems": 8,
        "schema": {
          "name": { "type": "text", "label": "Client Name" },
          "logo": { "type": "image", "label": "Logo" }
        }
      },
      "testimonials": {
        "type": "array",
        "label": "Testimonials",
        "maxItems": 4,
        "schema": {
          "quote": { "type": "textarea", "label": "Quote" },
          "author": { "type": "text", "label": "Author Name" },
          "role": { "type": "text", "label": "Role / Company" }
        }
      }
    }
  },
  "careers": {
    "type": "group",
    "label": "Careers Section",
    "fields": {
      "title": { "type": "text", "label": "Section Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "positions": {
        "type": "array",
        "label": "Job Positions",
        "maxItems": 10,
        "schema": {
          "title": { "type": "text", "label": "Position Title" },
          "type": { "type": "select", "label": "Employment Type", "options": ["Full-time", "Part-time", "Contract", "Internship"] },
          "location": { "type": "text", "label": "Location" },
          "description": { "type": "textarea", "label": "Description" }
        }
      },
      "formTitle": { "type": "text", "label": "Form Title", "placeholder": "Apply Now" },
      "formSubtitle": { "type": "text", "label": "Form Subtitle" }
    }
  },
  "contact": {
    "type": "group",
    "label": "Contact Section",
    "fields": {
      "title": { "type": "text", "label": "Section Title" },
      "subtitle": { "type": "text", "label": "Subtitle" },
      "phone": { "type": "text", "label": "Phone Number" },
      "email": { "type": "text", "label": "Email" },
      "address": { "type": "textarea", "label": "Address" },
      "mapEmbedUrl": { "type": "text", "label": "Google Maps Embed URL" }
    }
  },
  "footer": {
    "type": "group",
    "label": "Footer",
    "fields": {
      "copyright": { "type": "text", "label": "Copyright Text" },
      "socialLinks": {
        "type": "array",
        "label": "Social Media Links",
        "maxItems": 6,
        "schema": {
          "platform": { "type": "select", "label": "Platform", "options": ["twitter", "linkedin", "instagram", "facebook", "github", "youtube"] },
          "url": { "type": "text", "label": "URL" }
        }
      },
      "links": {
        "type": "array",
        "label": "Footer Links",
        "maxItems": 6,
        "schema": {
          "label": { "type": "text", "label": "Link Text" },
          "url": { "type": "text", "label": "URL" }
        }
      }
    }
  }
}
