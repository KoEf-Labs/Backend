DATABASE_URL="postgresql://postgres:postgres@localhost:5432/website_builder?schema=public"

# Generate with: npx tsx scripts/generate-keys.ts
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# CORS: comma-separated allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Set to "true" if behind a reverse proxy (nginx, Cloudflare)
TRUST_PROXY="false"

# Base URL for generated links (upload URLs, password reset links)
BASE_URL="http://localhost:3000"

# Base domain for subdomain routing (mysite.BASE_DOMAIN)
BASE_DOMAIN="yourapp.com"

# Redis (optional — falls back to in-memory if not set)
# REDIS_URL="redis://localhost:6379"

# Email — production uses local Postfix via SMTP_HOST=localhost.
# Falls back to Resend if SMTP_HOST is empty, or console if neither.
SMTP_HOST=""
SMTP_PORT="25"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@sitevra.com"
# RESEND_API_KEY="re_..."

# Static sites output directory
# SITES_DIR="/var/www/sites"

# Shared secret for internal service-to-service calls (AdminBackend → Backend)
INTERNAL_SERVICE_TOKEN=""

# Sentry error tracking (optional — leave blank to disable)
# SENTRY_DSN="https://xxxx@oxxxx.ingest.sentry.io/xxxx"

# Render worker tuning (optional)
# RENDER_TIMEOUT_MS="20000"
# RENDER_MAX_CONTENT_BYTES="2097152"

# OAuth providers (placeholders — fill in when credentials are issued)
# Google: the "Web Client ID" from Google Cloud Console. iOS/Android apps
# send their native-flow ID tokens which we verify against this audience.
GOOGLE_OAUTH_CLIENT_ID=""

# Apple Sign-In. Values come from Apple Developer portal:
#   TEAM_ID    — 10-char team ID
#   SERVICE_ID — the Services ID (reverse-DNS, e.g. com.example.app.web)
#   KEY_ID     — ID of the p8 key issued for Sign in with Apple
#   PRIVATE_KEY — contents of the downloaded AuthKey_xxx.p8 (PEM)
APPLE_TEAM_ID=""
APPLE_SERVICE_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# ── Payments ─────────────────────────────────────────────────────
# Stripe (global — USD/EUR/GBP/etc). Test keys start sk_test_/pk_test_.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""        # consumed by the mobile client
STRIPE_WEBHOOK_SECRET=""         # whsec_... — verify stripe-signature header

# Iyzico (TR — TRY). Sandbox host until live credentials are issued.
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# ── Subscriptions / IAP ──────────────────────────────────────────
# Apple App Store Server API + StoreKit 2 receipt verification.
# BUNDLE_ID must match the iOS target's Bundle Identifier exactly.
APPLE_BUNDLE_ID=""
# Google Play Billing verification.
# PACKAGE_NAME = the Android applicationId (e.g. com.sitevra.app).
# SERVICE_ACCOUNT_JSON = contents of the downloaded key.json, as a single line
# (escape the newlines in the private_key field, or paste as JSON).
GOOGLE_PLAY_PACKAGE_NAME=""
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=""
